{
  "name": "risk-assessment-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Enterprise risk assessment and management.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "assess_risk",
      "description": "Assess risk",
      "parameters": {
        "type": "object",
        "properties": {
          "risk_name": {
            "type": "string"
          },
          "likelihood": {
            "type": "integer"
          },
          "impact": {
            "type": "integer"
          },
          "category": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "create_risk_register",
      "description": "Create risk register",
      "parameters": {
        "type": "object",
        "properties": {
          "project_name": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          }
        },
        "required": [
          "project_name"
        ]
      }
    },
    {
      "name": "add_risk",
      "description": "Add risk to register",
      "parameters": {
        "type": "object",
        "properties": {
          "register_id": {
            "type": "string"
          },
          "risk_name": {
            "type": "string"
          },
          "likelihood": {
            "type": "integer"
          },
          "impact": {
            "type": "integer"
          },
          "category": {
            "type": "string"
          },
          "mitigation": {
            "type": "string"
          }
        },
        "required": [
          "register_id",
          "risk_name",
          "likelihood",
          "impact"
        ]
      }
    },
    {
      "name": "get_risk_register",
      "description": "Get risks in register",
      "parameters": {
        "type": "object",
        "properties": {
          "register_id": {
            "type": "string"
          }
        },
        "required": [
          "register_id"
        ]
      }
    },
    {
      "name": "update_risk_status",
      "description": "Update risk status",
      "parameters": {
        "type": "object",
        "properties": {
          "risk_id": {
            "type": "string"
          },
          "new_likelihood": {
            "type": "integer"
          },
          "new_impact": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "risk_id"
        ]
      }
    },
    {
      "name": "create_mitigation_plan",
      "description": "Create mitigation plan",
      "parameters": {
        "type": "object",
        "properties": {
          "risk_id": {
            "type": "string"
          },
          "actions": {
            "type": "array"
          },
          "owner": {
            "type": "string"
          },
          "due_date": {
            "type": "string"
          }
        },
        "required": [
          "risk_id"
        ]
      }
    },
    {
      "name": "get_mitigation_progress",
      "description": "Get mitigation progress",
      "parameters": {
        "type": "object",
        "properties": {
          "risk_id": {
            "type": "string"
          }
        },
        "required": [
          "risk_id"
        ]
      }
    },
    {
      "name": "calculate_reserve",
      "description": "Calculate contingency reserve",
      "parameters": {
        "type": "object",
        "properties": {
          "risks": {
            "type": "array"
          }
        },
        "required": []
      }
    },
    {
      "name": "risk_heatmap_data",
      "description": "Get heatmap data",
      "parameters": {
        "type": "object",
        "properties": {
          "register_id": {
            "type": "string"
          }
        },
        "required": [
          "register_id"
        ]
      }
    },
    {
      "name": "get_top_risks",
      "description": "Get highest priority risks",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "risk_trend_analysis",
      "description": "Analyze risk trends",
      "parameters": {
        "type": "object",
        "properties": {
          "register_id": {
            "type": "string"
          },
          "days": {
            "type": "integer"
          }
        },
        "required": [
          "register_id"
        ]
      }
    },
    {
      "name": "export_risk_report",
      "description": "Export risk report",
      "parameters": {
        "type": "object",
        "properties": {
          "register_id": {
            "type": "string"
          },
          "format": {
            "type": "string"
          }
        },
        "required": [
          "register_id"
        ]
      }
    }
  ]
}